# ============================================
# Context Engineering Multi-Agent System
# ============================================

# Anthropic API Key (required)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key (used for embeddings)
OPENAI_API_KEY=your_openai_api_key_here

# Target repository path to analyze/modify
REPO_PATH=./sample_repo

# ChromaDB settings (runs locally, no external service needed)
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=codebase

# Agent model settings
ORCHESTRATOR_MODEL=claude-opus-4-5-20251101
SUBAGENT_MODEL=claude-sonnet-4-20250514
INTENT_MODEL=claude-opus-4-5-20251101

# Retrieval settings
TOP_K_RESULTS=5
MAX_TOKENS_PER_AGENT=8000

# UI Server
UI_PORT=3000
